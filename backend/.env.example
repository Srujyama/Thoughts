# Firebase Web API key (Project settings → General → Web API Key).
# Used for the email/password REST auth endpoints (signup/login/refresh).
FIREBASE_WEB_API_KEY=your-web-api-key

# Default Cloud Storage bucket — NO gs:// prefix.
# New projects: PROJECT_ID.firebasestorage.app  |  legacy: PROJECT_ID.appspot.com
# (Check the exact name on the Firebase console Storage page.)
FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app

# Service-account credentials — provide ONE of the following:
#   (a) the JSON file contents inline (good for env-only deploys like Fly/Railway):
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...", ...}
#   (b) a path to the service-account JSON file:
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccount.json
